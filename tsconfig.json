{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@core/domain": ["src/core/domain/index.ts"],
      "@core/domain/*": ["src/core/domain/*"],
      "@features/*": ["src/features/*"],
      "@store/*": ["src/store/*"]
    },
    "types": ["jest", "node"],
    "lib": ["ES2022"]
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "__tests__/**/*.ts", "__tests__/**/*.tsx", "*.ts", "nativewind-env.d.ts"],
  "exclude": ["**/node_modules", "**/Pods", "android", "ios"]
}
