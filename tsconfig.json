{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "@core/domain": ["src/core/domain/index.ts"],
      "@core/domain/*": ["src/core/domain/*"],
      "@features/*": ["src/features/*"],
      "@store/*": ["src/store/*"]
    },
    "types": ["jest"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods", "android", "ios"]
}
